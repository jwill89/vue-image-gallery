{
    "name": "mathdad/gallery",
    "description": "A self-hosted personal media gallery for images, GIFs, and videos with Danbooru-style tagging.",
    "type": "project",
    "license": "MIT",
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "phpdocumentor/shim": true
        },
        "platform": {
            "php": "8.5.6"
        }
    },
    "require": {
        "ext-pdo": "*",
        "ext-pdo_sqlite": "*",
        "ext-curl": "*",
        "jenssegers/imagehash": "^0.11.0",
        "monolog/monolog": "^3.0",
        "slim/slim": "^4.0",
        "slim/psr7": "^1.0",
        "slim/http": "^1.0",
        "php-di/slim-bridge": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Gallery\\": ["includes/Gallery"],
            "Routes\\": ["api/Routes"]
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Gallery\\Tests\\": "tests/"
        }
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.0",
        "phpdocumentor/shim": "^3.0",
        "phpunit/phpunit": "^13.0",
        "roave/security-advisories": "dev-latest",
        "robmorgan/phinx": "^0.16",
        "squizlabs/php_codesniffer": "^4.0"
    },
    "scripts": {
        "lint": "phpcs",
        "lint:fix": "phpcbf",
        "test": "phpunit",
        "test:coverage": "phpunit --coverage-text"
    }
}
