# Allow large uploads (images/videos up to 100MB)
php_value upload_max_filesize 100M
php_value post_max_size 105M
php_value max_execution_time 120

RewriteEngine On

# ── Security: block direct access to sensitive files/dirs ───────────
# These rules MUST precede the "serve real files" rules below, which
# would otherwise hand out .env, the SQLite database, logs, caches, and
# raw source to anyone who requests them by path.
#
# Block any dot-file or dot-directory (.env, .git/, .htaccess, …).
RewriteRule (^|/)\. - [F,L]
# Block sensitive top-level files.
RewriteRule ^(composer\.(json|lock)|phinx\.php|package(-lock)?\.json|eslint\.config\.mjs|LICENSE|.*\.md)$ - [F,L]
# Block sensitive top-level directories.
RewriteRule ^(db|logs|cache|dupes|includes|vendor|scripts|node_modules)/ - [F,L]

# Serve built frontend assets from dist/ (JS, CSS, favicon, icons, etc.)
RewriteCond %{DOCUMENT_ROOT}/dist%{REQUEST_URI} -f
RewriteRule ^ dist%{REQUEST_URI} [L]

# Serve real files at the root level (media/full/*, media/thumbs/*, etc.)
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# Don't touch API requests (api/.htaccess handles its own routing)
RewriteCond %{REQUEST_URI} ^/api [NC]
RewriteRule ^ - [L]

# Route all other requests through the front controller for OG tags + SPA fallback
RewriteRule ^ index.php [QSA,L]
