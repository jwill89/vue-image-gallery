# Gallery configuration — copy to .env (same directory) and fill in real values.
# .env is gitignored; never commit real secrets.

# Admin password for protected endpoints (upload, delete, duplicates, etc.).
# Login is refused entirely if this is unset (so the insecure default can't be used).
GALLERY_ADMIN_PASSWORD=

# Public base URL (used to build absolute URLs for Danbooru tag fetching / IQDB fallback).
GALLERY_URL=https://gallery.example.com

# Comma-separated list of allowed origins (backs both CORS and the CSRF origin check).
GALLERY_ALLOWED_ORIGINS=https://gallery.example.com

# Optional: Danbooru API credentials for automatic tag importing.
DANBOORU_LOGIN=
DANBOORU_API_KEY=

# Optional: FontAwesome Kit ID (just the ID, not the full URL).
FONTAWESOME_KIT_ID=
