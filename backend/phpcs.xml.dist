<?xml version="1.0"?>
<ruleset name="Gallery">
    <description>PSR-12 coding standard for the Gallery PHP backend.</description>

    <!-- Paths to scan (run phpcs/phpcbf from backend/). -->
    <file>index.php</file>
    <file>phinx.php</file>
    <file>api</file>
    <file>includes</file>
    <file>scripts</file>
    <file>db/setup.php</file>
    <file>db/migrations</file>

    <!-- Never scan dependencies, generated data, or build artifacts. -->
    <exclude-pattern>*/vendor/*</exclude-pattern>
    <exclude-pattern>*/cache/*</exclude-pattern>
    <exclude-pattern>*/logs/*</exclude-pattern>
    <exclude-pattern>*/dist/*</exclude-pattern>

    <!-- Only PHP files; show progress and colours. -->
    <arg name="extensions" value="php"/>
    <arg name="colors"/>
    <arg value="p"/>

    <!-- The standard. -->
    <rule ref="PSR12"/>

    <!-- Phinx migration classes are intentionally global (loaded by filename, not
         autoloaded), so the PSR-1 "must be namespaced" rule does not apply to them. -->
    <rule ref="PSR1.Classes.ClassDeclaration.MissingNamespace">
        <exclude-pattern>db/migrations/*</exclude-pattern>
    </rule>

    <!-- PSR-12's 120-char line length is a soft recommendation: warn, never error,
         and don't let it fail CI (long SQL strings/comments are not worth wrapping). -->
    <rule ref="Generic.Files.LineLength">
        <properties>
            <property name="lineLimit" value="120"/>
            <property name="absoluteLineLimit" value="0"/>
        </properties>
    </rule>
    <config name="ignore_warnings_on_exit" value="1"/>
</ruleset>
