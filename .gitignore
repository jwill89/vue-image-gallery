# ── Repo-level ────────────────────────────────────────────────────────────────
/.idea/
/.vscode/
/.claude/
/IMPROVEMENTS.md

# Dev-only deploy script — holds the production host IP and the SSH key path. Never commit.
/scripts/

# ── Backend (PHP) ─────────────────────────────────────────────────────────────
# Dependencies are reinstalled via composer; composer.lock IS tracked (reproducible installs).
/backend/vendor/
# Secrets and runtime / generated data — never commit.
/backend/.env
/backend/db/gallery.db
/backend/cache/
/backend/logs/
/backend/dupes/
/backend/media/
# Test artifacts.
/backend/.phpunit.cache/
/backend/coverage/

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
# Dependencies are reinstalled via npm ci; package-lock.json IS tracked.
/frontend/node_modules/
/frontend/dist/
/frontend/coverage/
/frontend/.gitignore
/frontend/.vscode/
# Generated / branding assets supplied at deploy time.
/frontend/public/favicon.png
/frontend/public/icons.svg
